# Camstar Modeling MCP Server - Environment Variables
# Copy this file to .env and fill in your values.

# Base URL of the Camstar Modeling API (no trailing slash)
CAMSTAR_BASE_URL=https://172.27.251.56/Modeling

# API Authentication Credentials
CAMSTAR_USERNAME=CamstarAdmin
CAMSTAR_PASSWORD=Cam1star

# HTTP request timeout in seconds (default: 30)
CAMSTAR_TIMEOUT=30

# Maximum response length (characters) before truncation kicks in (default: 4000)
MAX_RESPONSE_LENGTH=4000

# LLM 大模型配置（兼容 OpenAI 协议的任意模型）
# 支持: DeepSeek / Qwen (通义千问) / GLM (智谱) / Ollama 本地模型 等
LLM_API_KEY=sk-e258e65ced244d40a2de433fb667dfab
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

ENABLE_PERFORMANCE_LOG=True

# ---------------------------------------------------------------------------
# 安全卡点阈值配置 (防误触保护)
# ---------------------------------------------------------------------------
# 批量创建超过多少条时要求先确认 (默认 20)
SAFE_CREATE_THRESHOLD=20
# 批量更新或修改超过多少条时要求先确认 (默认 3)
SAFE_UPDATE_THRESHOLD=3
# 批量删除超过多少条时要求先确认 (默认 0 表示 >= 1 即全量拦截)
SAFE_DELETE_THRESHOLD=0
